# Signus API base URL (no trailing slash)
BASE_URL=https://api.signus.ai

# Your account ID (UUID) — find it in Signus UI under Settings > Account
ACCOUNT_ID=

# Your API key — create one in Signus UI under Settings > API Keys
SIGNUS_API_KEY=

# Template ID (UUID) — the template to create documents from
# Create a template in Signus UI with at least one file, one signer recipient, and one signature field
TEMPLATE_ID=

# Recipient ID (UUID) — the signer slot in your template
# Run the test once with just the above vars filled in — the "Get template details" step
# will print the recipient IDs so you can copy the right one here
TEMPLATE_RECIPIENT_ID=

# Signer details for the document (optional — defaults shown)
SIGNER_NAME=Jane Doe
SIGNER_EMAIL=jane.doe@example.com
